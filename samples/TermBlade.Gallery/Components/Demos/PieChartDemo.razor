<Box Width="100%" Height="100%" FlexDirection="FlexDirection.Column" BackgroundColor="#0d1117">
    <Box Width="100%" Height="1">
        <Text Content="Pie Chart" Fg="#58a6ff" Width="30" Height="1" Attributes="@TextAttributes.Bold" />
    </Box>
    <Box Width="100%" FlexGrow="1" FlexDirection="FlexDirection.Row">
        <PieChart Width="50%" Height="100%" Data="@PieData" AnimationDuration="1.5" />
        <Box FlexGrow="1" FlexDirection="FlexDirection.Column">
            <Box Width="100%" Height="1">
                <Text Content="No Animation" Fg="#f0883e" Width="30" Height="1" Attributes="@TextAttributes.Bold" />
            </Box>
            <PieChart Width="100%" FlexGrow="1" Data="@PieData" AnimationDuration="0" />
        </Box>
    </Box>
</Box>

@code {
    private static readonly IReadOnlyList<PieSlice> PieData =
    [
        new PieSlice(35, "C#", "#58a6ff"),
        new PieSlice(25, "TypeScript", "#3fb950"),
        new PieSlice(20, "Python", "#f0883e"),
        new PieSlice(12, "Rust", "#f85149"),
        new PieSlice(8, "Go", "#bc8cff"),
    ];
}
