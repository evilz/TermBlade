@using TermBlade.Core.Renderables

<TimeSeriesLineChart Width="100%" Height="100%" Data="@TimeData" Title="Server Response Time"
                     LineColor="#f0883e" FillColor="#9e6a03" TimeFormat="HH:mm" />

@code {
    private static readonly IReadOnlyList<TimeSeriesPoint> TimeData = GenerateData();

    private static IReadOnlyList<TimeSeriesPoint> GenerateData()
    {
        var points = new List<TimeSeriesPoint>();
        var start = new DateTimeOffset(2025, 1, 15, 9, 0, 0, TimeSpan.Zero);
        var random = new Random(42);
        double value = 45;

        for (int i = 0; i < 60; i++)
        {
            value += random.NextDouble() * 10 - 4.5;
            value = Math.Clamp(value, 20, 120);
            points.Add(new TimeSeriesPoint(start.AddMinutes(i * 5), value));
        }

        return points;
    }
}
