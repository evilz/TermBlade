@inherits GalleryComponentBase

<Box Width="100%" Height="100%" BackgroundColor="#0d1117" FlexDirection="FlexDirection.Row">

    <Box Width="28" Height="100%" Border="true" BorderColor="#30363d" Title=" Gallery " BackgroundColor="#0d1117" PaddingTop="1" PaddingRight="1" PaddingBottom="1" PaddingLeft="1">
        @for (var i = MenuWindow.StartIndex; i < MenuWindow.StartIndex + MenuWindow.Count; i++)
        {
            var isSelected = i == SelectedIndex;
            var fg = isSelected ? "#ffffff" : "#8b949e";
            var bg = isSelected ? "#1f6feb" : "#0d1117";
            var label = GetEntryLabel(i);
            var attrs = isSelected ? TextAttributes.Bold : TextAttributes.None;
            <Box Width="26" Height="1" BackgroundColor="@bg">
                <Text Content="@label" Fg="@fg" Bg="@bg" Width="26" Height="1" Attributes="@attrs" />
            </Box>
        }
    </Box>

    <Box FlexGrow="1" Height="100%" FlexDirection="FlexDirection.Column" BackgroundColor="#0d1117" PaddingLeft="2" PaddingRight="2">

        <Text Content="@CurrentEntry.Name" Fg="#58a6ff" Width="100%" Height="1" Attributes="@TextAttributes.Bold" />
        <Text Content="@CurrentEntry.Description" Fg="#c9d1d9" Width="100%" Height="1" />
        <Text Content="@SourceLabel" Fg="#f0883e" Width="100%" Height="1" />
        <TabSelect Width="100%" Height="1" Tabs="@ContentTabs" SelectedIndex="@((int)SelectedTab)"
                   SelectedIndexChanged="@SetSelectedTab" ActiveFg="#ffffff" ActiveBg="#1f6feb"
                   InactiveFg="#8b949e" InactiveBg="#161b22" />

        <Box Width="100%" FlexGrow="1" Border="true" BorderColor="#30363d" Title="@ContentPanelTitle" BackgroundColor="#161b22" PaddingLeft="1" PaddingRight="1" PaddingTop="1" PaddingBottom="1" MarginTop="1">
            @if (SelectedTab == GalleryContentTab.Preview)
            {
                @PreviewFragment
            }
            else
            {
                <Code Width="100%" Height="100%" Language="razor" ShowLineNumbers="true" Content="@CurrentEntry.RazorCode" />
            }
        </Box>
    </Box>
</Box>

@code {
    private static readonly List<string> ContentTabs = ["Preview", "Source"];

    private IReadOnlyList<GalleryEntry> Entries => GalleryCatalog.Entries;

    private int SelectedIndex { get; set; }

    private GalleryContentTab SelectedTab { get; set; } = GalleryContentTab.Preview;

    private GalleryEntry CurrentEntry => Entries[SelectedIndex];

    private GalleryViewportLayout Viewport => GalleryViewportLayout.Create(App.Renderer.TerminalHeight);

    private GalleryMenuWindow MenuWindow => GalleryMenuWindow.Create(Entries.Count, SelectedIndex, MenuCapacity);

    private string SourceLabel => "Source Code: " + CurrentEntry.SourceFile;

    private string ContentPanelTitle => SelectedTab == GalleryContentTab.Preview ? " Preview " : " Source ";

    private int MenuCapacity => Viewport.MenuCapacity;

    private string GetEntryLabel(int index)
    {
        var prefix = index == SelectedIndex ? "> " : "  ";
        return prefix + Entries[index].Name;
    }

    private RenderFragment PreviewFragment => SelectedIndex switch
    {
        0 => RenderComponent<BoxDemo>(),
        1 => RenderComponent<TextDemo>(),
        2 => RenderComponent<CodeDemo>(),
        3 => RenderComponent<AsciiFontDemo>(),
        4 => RenderComponent<LineNumbersDemo>(),
        5 => RenderComponent<FrameBufferDemo>(),
        6 => RenderComponent<SelectDemo>(),
        7 => RenderComponent<InputDemo>(),
        8 => RenderComponent<SliderDemo>(),
        9 => RenderComponent<TabSelectDemo>(),
        10 => RenderComponent<MarkdownDemo>(),
        11 => RenderComponent<DiffDemo>(),
        12 => RenderComponent<ScrollBoxDemo>(),
        13 => RenderComponent<ScrollBarDemo>(),
        14 => RenderComponent<ConsoleOverlayDemo>(),
        15 => RenderComponent<BarChartDemo>(),
        16 => RenderComponent<LineChartDemo>(),
        17 => RenderComponent<TimeSeriesLineChartDemo>(),
        18 => RenderComponent<HeatMapDemo>(),
        19 => RenderComponent<CandlestickChartDemo>(),
        20 => RenderComponent<PieChartDemo>(),
        21 => RenderComponent<DoughnutChartDemo>(),
        22 => RenderComponent<TreeViewDemo>(),
        23 => RenderComponent<CalendarDemo>(),
        24 => RenderComponent<TextareaDemo>(),
        25 => RenderComponent<ConfirmDemo>(),
        26 => RenderComponent<SpinnerDemo>(),
        27 => RenderComponent<MultiSelectDemo>(),
        _ => RenderComponent<BoxDemo>(),
    };

    protected override void OnInitialized()
    {
        SetBackground("#0d1117");
        RegisterKeypress(HandleKeypress);
    }

    private void HandleKeypress(KeyEvent key)
    {
        switch (key.Name)
        {
            case "up":
                key.PreventDefault();
                SelectedIndex = (SelectedIndex - 1 + Entries.Count) % Entries.Count;
                InvokeAsync(StateHasChanged);
                break;
            case "down":
                key.PreventDefault();
                SelectedIndex = (SelectedIndex + 1) % Entries.Count;
                InvokeAsync(StateHasChanged);
                break;
            case "left":
                key.PreventDefault();
                SelectedTab = GalleryContentTabNavigation.Move(SelectedTab, -1);
                InvokeAsync(StateHasChanged);
                break;
            case "right":
                key.PreventDefault();
                SelectedTab = GalleryContentTabNavigation.Move(SelectedTab, 1);
                InvokeAsync(StateHasChanged);
                break;
        }
    }

    private void SetSelectedTab(int index)
    {
        SelectedTab = (GalleryContentTab)index;
    }

    private static RenderFragment RenderComponent<TComponent>() where TComponent : Microsoft.AspNetCore.Components.IComponent
        => builder =>
        {
            builder.OpenComponent<TComponent>(0);
            builder.CloseComponent();
        };
}
