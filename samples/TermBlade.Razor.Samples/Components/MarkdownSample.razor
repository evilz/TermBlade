@inherits SampleComponentBase

<Box Width="100%" Height="100%" BackgroundColor="#0b1020" PaddingTop="1" PaddingLeft="2" PaddingRight="2">
    <Box Width="100%" Height="100%" Border="true" BorderColor="#7aa2f7" Title=" Markdown Sample " PaddingTop="1" PaddingLeft="1" PaddingRight="1" PaddingBottom="2" BackgroundColor="#111827">
        <Markdown Width="100%" FlexGrow="1" Content="@MarkdownContent" />
        <Text Content="Press q or Esc to exit" Fg="#8b949e" LayoutPosition="absolute" Left="2" Bottom="1" Width="24" Height="1" />
    </Box>
</Box>

@code {
    private const string MarkdownContent = @"# TermBlade Razor

## Highlights

- Razor-hosted terminal UI
- Existing renderables exposed as components
- **Bold**, *italic*, `inline code`, and links
- Unicode: ✅ ⚠️ 🚀 世界

> Built to feel closer to RazorConsole while keeping the TermBlade engine.

### Code

```csharp
builder.UseTermBladeRazor<MySample>();
```

### Ordered list

1. Create a component
2. Add renderables
3. Run the sample

### Checklist

- [x] Markdown component
- [x] Razor bindings
- [ ] Your next sample

---

| Component | Purpose |
| --- | --- |
| Box | Layout and borders |
| Textarea | Editing |
| ScrollBox | Clipped scrolling |
";

    protected override void OnInitialized()
    {
        SetBackground("#0b1020");
        RegisterExitKeys();
    }
}
