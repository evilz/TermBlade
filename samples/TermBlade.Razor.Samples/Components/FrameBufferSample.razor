@inherits SampleComponentBase

<Box Width="100%" Height="100%" BackgroundColor="#000014" PaddingTop="1" PaddingLeft="2" PaddingRight="2">
    <Box Width="100%" Height="100%" Border="true" BorderColor="#888888" Title=" FrameBuffer Demo " BackgroundColor="#000014" PaddingBottom="2">
        <FrameBuffer @ref="_frameBuffer" Width="100%" Height="100%" PixelWidth="120" PixelHeight="40" />
        <Text Content="Press q or Escape to quit" Fg="#888888" LayoutPosition="absolute" Left="2" Bottom="1" Width="26" Height="1" />
    </Box>
</Box>

@code {
    private FrameBuffer? _frameBuffer;
    private float _time;

    protected override void OnInitialized()
    {
        SetBackground("#000014");
        RegisterExitKeys();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            CreateTimer(_ => DrawFrame(), TimeSpan.FromMilliseconds(50));
        }

        return Task.CompletedTask;
    }

    private void DrawFrame()
    {
        var target = _frameBuffer?.Renderable;
        if (target == null)
            return;

        _time += 0.05f;
        target.Clear(Rgba.FromInts(0, 0, 20));
        var cx = (int)(60 + 40 * MathF.Cos(_time));
        var cy = (int)(20 + 15 * MathF.Sin(_time));
        target.DrawCircle(cx, cy, 8, Rgba.FromCss("#00aaff"));
        target.DrawCircle(60, 20, 15, Rgba.FromCss("#ff4488"));
        target.DrawLine(0, 0, 119, 39, Rgba.FromCss("#88ff00"));
        App.RequestRender();
    }
}
