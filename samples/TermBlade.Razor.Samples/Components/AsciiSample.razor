    @if (_showCommandModal)
    {
        <Box Width="100%" Height="100%" LayoutPosition="absolute" Left="0" Top="0" BackgroundColor="@ModalBackdrop" ZIndex="80" Opacity="@ModalBackdropOpacity" />
        <Box Width="72" Height="14" LayoutPosition="absolute" Left="20" Top="8" BackgroundColor="#111827" Border="true" BorderColor="#6057ff" Title=" Command Palette " ZIndex="100" PaddingTop="1" PaddingLeft="2" PaddingRight="2">
