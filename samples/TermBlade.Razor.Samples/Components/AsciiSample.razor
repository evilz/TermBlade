            <Text Content="  /tools status" Fg="#d1d5db" Bg="#111827" Width="66" Height="1" />
            <Text Content="" Fg="#111827" Bg="#111827" Width="66" Height="1" />
            <Text Content="Ctrl+P: close modal • Esc: close modal • q: quit sample" Fg="#6b7280" Bg="#111827" Width="66" Height="1" />
        </Box>
    }
</Box>

@code {
    private const string CanvasBackground = "#1b1c2a";
    private const string MintAccent = "#14d8a6";
    private const string ModalBackdrop = "#11131f";
    private const float ModalBackdropOpacity = 0.88f;
    private static readonly string HeaderSlashes = new('╱', 60);
    private bool _showCommandModal;

    protected override void OnInitialized()
    {
        SetBackground(CanvasBackground);
        RegisterKeypress(HandleKeypress);
    }

    private void HandleKeypress(KeyEvent key)
    {
        if (key.Name == "ctrl+p")
        {
            key.PreventDefault();
            _showCommandModal = !_showCommandModal;
            InvokeAsync(StateHasChanged);
            return;
        }

        if (_showCommandModal && key.Name == "escape")
        {
            key.PreventDefault();
            _showCommandModal = false;
            InvokeAsync(StateHasChanged);
            return;
        }

        if (!_showCommandModal && key.Name is "q" or "escape")
        {
            key.PreventDefault();
            Exit();
        }
    }
}
